{
    "name": "secuconnect/secuconnect-php-sdk-shop-modules",
    "version": "0.9.0",
    "homepage": "https://github.com/secuconnect/secuconnect-php-sdk-shop-modules",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "secupay AG - secuconnect",
            "homepage": "https://secuconnect.com/"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/cache": "^1 || ^2 || ^3",
        "psr/log": "^1 || ^2 || ^3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.50 || ^12.5.8 || ^13",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Secuconnect\\Client\\" : "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Secuconnect\\Client\\" : "test/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "phpstan": "phpstan analyse ./lib/ -l8"
    }
}
